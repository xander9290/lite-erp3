generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Partner {
  id              String             @id @default(cuid())
  name            String
  email           String?
  imageUrl        String?            @default("/images/avatar_default.svg")
  phone           String?
  street          String?
  houseNumber     String?            @map("house_number")
  streets         String?
  town            String?
  zip             Int?
  county          String?
  province        String?
  country         String?
  completeAddress String?            @map("complete_address")
  vat             String?
  displayType     PartnerDisplayType @default(INTERNAL) @map("display_type")
  active          Boolean            @default(true)
  createdUid      String             @map("created_uid")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  userId          String?            @map("user_id")
  mobile          String?
  Company         Company?           @relation("PartnerCompanyRel")
  UserManager     User?              @relation("PartnerManagerRel", fields: [userId], references: [id], onDelete: Cascade)
  Products        ProductTemplate[]  @relation("ProductSupplierRel")
  PurchaseOrders  PurchaseOrder[]
  User            User?              @relation("PartnerUserRelated")
  Tags            Tag[]              @relation("PartnerTagsRelation")

  @@index([name])
  @@map("partners")
}

model User {
  id               String            @id @default(cuid())
  name             String
  login            String            @unique
  password         String
  lastLogin        DateTime?         @map("last_login")
  active           Boolean           @default(true)
  partnerId        String?           @unique @map("partner_id")
  groupId          String?           @map("group_id")
  createdUid       String            @map("created_uid")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  Auditlogs        Auditlog[]        @relation("UserAuditlogRel")
  ManagedCompanies Company[]         @relation("UserManageCompanyRel")
  PartnerManager   Partner[]         @relation("PartnerManagerRel")
  Products         ProductTemplate[] @relation("ProductUserRel")
  PurchaseOrders   PurchaseOrder[]
  StockMoves       StockMove[]
  Group            Group?            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  Partner          Partner?          @relation("PartnerUserRelated", fields: [partnerId], references: [id], onDelete: Cascade)
  Companies        Company[]         @relation("UserCompanyRel")

  @@map("users")
}

model Auditlog {
  id         String          @id @default(cuid())
  action     AuditlogActions
  entityType String          @map("entity_type")
  entityId   String          @map("entity_id")
  log        String
  userId     String          @map("user_id")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  User       User            @relation("UserAuditlogRel", fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId, createdAt])
  @@index([userId])
  @@map("auditlogs")
}

model Group {
  id         String      @id @default(cuid())
  name       String      @unique
  active     Boolean     @default(true)
  createdUid String      @map("created_uid")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  GroupLines GroupLine[] @relation("GroupLineRel")
  Users      User[]

  @@map("groups")
}

model GroupLine {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type")
  fieldName  String   @map("field_name")
  invisible  Boolean  @default(false)
  readonly   Boolean  @default(false)
  required   Boolean  @default(false)
  notCreate  Boolean  @default(false) @map("not_create")
  notEdit    Boolean  @default(false) @map("not_edit")
  modelId    String   @map("model_id")
  fieldId    String   @map("field_id")
  groupId    String   @map("group_id")
  createdUid String   @map("created_uid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  Group      Group    @relation("GroupLineRel", fields: [groupId], references: [id], onDelete: Cascade)

  @@index([entityType, fieldName])
}

model Model {
  id          String       @id @default(cuid())
  name        String       @unique
  label       String       @unique
  description String
  active      Boolean      @default(false)
  createdUid  String       @map("created_uid")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  ModelFields ModelField[] @relation("ModelFieldRel")

  @@map("models")
}

model ModelField {
  id          String    @id @default(cuid())
  name        String
  label       String
  description String
  fieldType   FieldType @map("field_type")
  active      Boolean   @default(false)
  modelId     String    @map("model_id")
  createdUid  String    @map("created_uid")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  Model       Model     @relation("ModelFieldRel", fields: [modelId], references: [id], onDelete: Cascade)

  @@index([name])
  @@map("model_fields")
}

model Tag {
  id              String            @id @default(cuid())
  name            String
  entityName      String            @map("entity_name")
  ProductTemplate ProductTemplate[] @relation("ProductTemplateToTag")
  Partner         Partner[]         @relation("PartnerTagsRelation")

  @@index([name, entityName])
  @@map("tags")
}

model Company {
  id             String          @id @default(cuid())
  name           String          @unique
  code           String          @unique
  active         Boolean         @default(true)
  managerId      String?         @map("manager_id")
  partnerId      String          @unique @map("partner_id")
  parentId       String?         @map("parent_id")
  createdUid     String          @map("created_uid")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  Manager        User?           @relation("UserManageCompanyRel", fields: [managerId], references: [id], onDelete: Cascade)
  Company        Company?        @relation("ParentChildrenCompany", fields: [parentId], references: [id], onDelete: Cascade)
  Children       Company[]       @relation("ParentChildrenCompany")
  Partner        Partner         @relation("PartnerCompanyRel", fields: [partnerId], references: [id], onDelete: Cascade)
  Manufacturings Manufacturing[]
  stockMoves     StockMove[]
  Warehouses     Warehouse[]     @relation("WarehouseCompanyRel")
  Users          User[]          @relation("UserCompanyRel")

  @@map("companies")
}

model Warehouse {
  id          String        @id @default(cuid())
  name        String        @unique
  code        String        @unique
  description String        @unique
  type        WarehouseType @default(SALES)
  active      Boolean       @default(true)

  companyId String  @map("company_id")
  Company   Company @relation("WarehouseCompanyRel", fields: [companyId], references: [id], onDelete: Cascade)

  InternalsFrom Warehouse[] @relation("InternalsWarehouseRel")
  InternalsTo   Warehouse[] @relation("InternalsWarehouseRel")

  OriginStockMoves StockMove[] @relation("OriginWarehouseMove")
  DestStockMoves   StockMove[] @relation("DestWarehouseMove")

  Stocks StockWarehouse[]

  ManufacturingsOrgin Manufacturing[] @relation("ManufacturingWhOrigin")
  ManufacturingsDest  Manufacturing[] @relation("ManufacturingWhDes")

  createdUid             String          @map("created_uid")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")
  purchaseOrders         PurchaseOrder[]
  purchaseOrdersSupplier PurchaseOrder[] @relation("WarehousePurchaseAffected")

  @@map("warehouses")
}

model StockWarehouse {
  id           String          @id @default(cuid())
  qty          Float           @default(0.0)
  reservedQty  Float           @default(0.0) @map("reserved_qty")
  locationName String?
  productId    String          @map("product_id")
  warehouseId  String          @map("warehouse_id")
  createdUid   String          @map("created_uid")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  Product      ProductTemplate @relation(fields: [productId], references: [id])
  Warehouse    Warehouse       @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId], name: "productId_warehouseId")
  @@map("stock_warehouse")
}

model StockMove {
  id              String          @id @default(cuid())
  name            String
  reference       String
  quantity        Float           @default(0.0)
  date            DateTime        @default(now()) @db.Date
  productId       String          @map("product_id")
  warehouseId     String          @map("warehouse_id")
  warehouseDestId String          @map("warehouse_dest_id")
  userId          String          @map("user_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  moveType        StockMoveType   @map("move_type")
  companyId       String          @map("company_id")
  Company         Company         @relation(fields: [companyId], references: [id])
  Product         ProductTemplate @relation(fields: [productId], references: [id])
  User            User            @relation(fields: [userId], references: [id])
  WarehouseDest   Warehouse       @relation("DestWarehouseMove", fields: [warehouseDestId], references: [id])
  WarehouseOrigin Warehouse       @relation("OriginWarehouseMove", fields: [warehouseId], references: [id])

  @@map("stock_move")
}

model ProductTemplate {
  id                    String                 @id @default(cuid())
  name                  String                 @unique
  description           String                 @unique
  defaultCode           String                 @unique @map("default_code")
  active                Boolean                @default(true)
  sales                 Boolean                @default(true)
  purchases             Boolean                @default(true)
  imageUrl              String?                @default("/image/avatar_default.svg") @map("image_url")
  price1                Float                  @default(0.00) @map("price_1")
  price2                Float                  @default(0.00) @map("price_2")
  price3                Float                  @default(0.00) @map("price_3")
  price4                Float                  @default(0.00) @map("price_4")
  price5                Float                  @default(0.00) @map("price_5")
  lastCost              Float                  @default(0.00) @map("last_cost")
  standarPrice          Float                  @default(0.0) @map("standard_price")
  weight                Float                  @default(0.00)
  volume                Float                  @default(0.00)
  ancho                 Float                  @default(0.00)
  alto                  Float                  @default(0.00)
  largo                 Float                  @default(0.00)
  uomIncomingAllowed    Float                  @default(1.0) @map("uom_incoming_allowed")
  uomOutgoingAllowed    Float                  @default(1.0) @map("uom_outgoing_allowed")
  supplierId            String?                @map("supplier_id")
  userId                String?                @map("user_id")
  createUid             String                 @map("create_uid")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  displayType           ProductDisplayType     @default(PRODUCT) @map("display_type")
  state                 ProductStateType       @default(AVAILABLE)
  productCategoryId     String?                @map("product_category_id")
  productBrandId        String?                @map("product_brand_id")
  uomId                 String?                @map("uom_id")
  manufacturing         Boolean                @default(false)
  yield                 Float                  @default(0.00)
  Manufacturings        Manufacturing[]
  ManufacturingLines    ManufacturingLine[]
  ProductPackagingLines ProductPackagingLine[]
  ReceiptLines          ProductReceiptLine[]   @relation("ParentProductReceipt")
  ProductReceiptLines   ProductReceiptLine[]   @relation("ProductReceipt")
  ProductBrand          ProductBrand?          @relation(fields: [productBrandId], references: [id])
  ProductCategory       ProductCategory?       @relation(fields: [productCategoryId], references: [id])
  Supplier              Partner?               @relation("ProductSupplierRel", fields: [supplierId], references: [id])
  Uom                   UomCategory?           @relation(fields: [uomId], references: [id])
  User                  User?                  @relation("ProductUserRel", fields: [userId], references: [id])
  StockMoves            StockMove[]
  Stocks                StockWarehouse[]
  Tags                  Tag[]                  @relation("ProductTemplateToTag")
  purchaseOrderLines    PurchaseOrderLine[]
  taxSaleId             String?                @map("tax_sale_id")
  TaxSale               InvoicingTax?          @relation("PTSaleTax", fields: [taxSaleId], references: [id], onDelete: Restrict)
  taxPurchaseId         String?                @map("tax_purchase_id")
  TaxPurchase           InvoicingTax?          @relation("PTPurchaseTax", fields: [taxPurchaseId], references: [id], onDelete: Restrict)

  @@map("product_template")
}

model ProductCategory {
  id          String            @id @default(cuid())
  name        String            @unique
  createUid   String            @map("create_uid")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  parentId    String?           @map("parent_id")
  description String
  active      Boolean           @default(true)
  Parent      ProductCategory?  @relation("ParentProductCategoryRel", fields: [parentId], references: [id], onDelete: Cascade)
  Children    ProductCategory[] @relation("ParentProductCategoryRel")
  Products    ProductTemplate[]

  @@map("product_category")
}

model ProductBrand {
  id          String            @id @default(cuid())
  name        String            @unique
  description String            @unique
  code        String            @unique
  active      Boolean           @default(true)
  createUid   String            @map("create_uid")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  Products    ProductTemplate[]

  @@map("product_brand")
}

model UomCategory {
  id                    String                 @id @default(cuid())
  name                  String                 @unique
  description           String                 @unique
  code                  String                 @unique
  ratio                 Float                  @default(0.0)
  isBaseUnit            Boolean                @default(false) @map("is_base_unit")
  active                Boolean                @default(true)
  createUid             String                 @map("create_uid")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  Manufacturings        Manufacturing[]
  ManufacturingLines    ManufacturingLine[]
  productPackagingLines ProductPackagingLine[]
  ProductReceiptLines   ProductReceiptLine[]
  Products              ProductTemplate[]
  purchaseOrderLines    PurchaseOrderLine[]

  @@map("product_uom_category")
}

model ProductPackaging {
  id                    String                 @id @default(cuid())
  name                  String                 @unique
  active                Boolean                @default(true)
  createUid             String                 @map("create_uid")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  ProductPackagingLines ProductPackagingLine[]

  @@map("product_packaging")
}

model ProductPackagingLine {
  id               String           @id @default(cuid())
  qty              Float            @default(0.0)
  packagingId      String           @map("packagin_id")
  productId        String           @map("product_id")
  createUid        String           @map("create_uid")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  uomId            String           @map("uom_id")
  ProductPackaging ProductPackaging @relation(fields: [packagingId], references: [id])
  Product          ProductTemplate  @relation(fields: [productId], references: [id], onDelete: Cascade)
  Uom              UomCategory      @relation(fields: [uomId], references: [id])

  @@map("product_packaging_line")
}

model ProductReceiptLine {
  id        String          @id @default(cuid())
  qty       Float           @default(0.0)
  productId String          @map("product_id")
  uomId     String          @map("uom_id")
  createUid String          @map("create_uid")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  active    Boolean         @default(true)
  parentId  String          @map("parent_id")
  Parent    ProductTemplate @relation("ParentProductReceipt", fields: [parentId], references: [id])
  Product   ProductTemplate @relation("ProductReceipt", fields: [productId], references: [id])
  Uom       UomCategory     @relation(fields: [uomId], references: [id])

  @@map("product_receipt_line")
}

model Manufacturing {
  id                 String              @id @default(cuid())
  name               String              @unique
  state              ManufacturingState  @default(draft)
  quantity           Float               @default(0.0)
  productId          String              @map("product_id")
  companyId          String              @map("company_id")
  whOriginId         String              @map("wh_origin_id")
  whDestId           String              @map("wh_dest_id")
  createUid          String              @map("create_uid")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  date               DateTime            @default(now()) @db.Date
  uomId              String              @map("uom_id")
  yield              Float               @default(0.0)
  priceUnit          Float               @default(0.0) @map("price_unit")
  Company            Company             @relation(fields: [companyId], references: [id])
  Product            ProductTemplate     @relation(fields: [productId], references: [id])
  Uom                UomCategory         @relation(fields: [uomId], references: [id])
  WhDest             Warehouse           @relation("ManufacturingWhDes", fields: [whDestId], references: [id])
  WhOrigin           Warehouse           @relation("ManufacturingWhOrigin", fields: [whOriginId], references: [id])
  ManufacturingLines ManufacturingLine[]

  @@map("manufacturing")
}

model ManufacturingLine {
  id                  String          @id @default(cuid())
  outQty              Float           @default(0.0) @map("out_qty")
  manufacturingId     String          @map("manufacturing_id")
  productIngredientId String          @map("product_ingredient_id")
  createUid           String          @map("create_uid")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  uomId               String          @map("uom_id")
  priceUnit           Float           @default(0.0) @map("price_unit")
  Manufacturing       Manufacturing   @relation(fields: [manufacturingId], references: [id], onDelete: Cascade)
  Product             ProductTemplate @relation(fields: [productIngredientId], references: [id])
  Uom                 UomCategory     @relation(fields: [uomId], references: [id])

  @@map("manufacturing_line")
}

model Counter {
  id    String @id
  value Int

  @@map("counters")
}

model PurchaseOrder {
  id                  String               @id @default(cuid())
  name                String               @unique
  supplierId          String               @map("supplier_id")
  userId              String               @map("user_id")
  warehouseDestId     String               @map("wh_dest_id")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  state               PurchaseOrderState   @default(draft)
  subtotal            Float                @default(0.0)
  amountTax           Float                @default(0.0) @map("amount_tax")
  total               Float                @default(0.0)
  date                DateTime             @db.Date
  dateOrder           DateTime             @map("date_order") @db.Date
  datePlanned         DateTime?            @map("date_planned") @db.Date
  confirmedDate       DateTime?            @map("confirmed_date")
  doneDate            DateTime?            @map("done_date")
  Supplier            Partner              @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  User                User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  WarehouseDest       Warehouse            @relation(fields: [warehouseDestId], references: [id], onDelete: Restrict)
  paymentTermId       String               @map("payment_term_id")
  PaymentTerm         InvoicingPaymentTerm @relation(fields: [paymentTermId], references: [id], onDelete: Restrict)
  OrderLines          PurchaseOrderLine[]
  warehouseAffectedId String?              @map("warehouse_affected_id")
  WarehouseAffected   Warehouse?           @relation("WarehousePurchaseAffected", fields: [warehouseAffectedId], references: [id], onDelete: Restrict)

  @@map("purchase_order")
}

model PurchaseOrderLine {
  id        String @id @default(cuid())
  priceUnit Float  @default(0.0) @map("price_unit")
  quantity  Float  @default(0.0)
  subtotal  Float  @default(0.0)
  total     Float  @default(0.0)
  taxRate   Float  @map("tax_rate")
  taxAmount Float  @map("tax_amount")

  receivedQty Float              @default(0.0) @map("received_qty")
  pendingQty  Float              @default(0.0) @map("pending_qty")
  invoicedQty Float              @default(0.0) @map("invoiced_qty")
  state       PurchaseLineStates @default(pending)

  ready Boolean @default(false)

  orderId      String        @map("order_id")
  PurcaseOrder PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)

  productId String          @map("product_id")
  Product   ProductTemplate @relation(fields: [productId], references: [id], onDelete: Restrict)

  uomId String      @map("uom_id")
  Uom   UomCategory @relation(fields: [uomId], references: [id], onDelete: Restrict)

  createUid String   @map("create_uid")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("purchase_order_line")
}

enum PurchaseLineStates {
  pending
  done
  invoiced
  cancel
}

enum PartnerDisplayType {
  INTERNAL
  CUSTOMER
  SUPPLIER
  CONTACT
  DELIVERY
}

enum AuditlogActions {
  create
  update
  read
  delete
}

enum FieldType {
  string
  number
  relation
  action
  link
  boolean
  date
  datetime
}

enum WarehouseType {
  SALES
  SUPPLY
  PRODUCTION
  QUARANTINE
  ADJUSTMENT
  TRANSIT
  OUTGOING
}

enum StockMoveType {
  outgoing
  incoming
}

enum ProductDisplayType {
  CONSU
  SERVICE
  PRODUCT
}

enum ProductStateType {
  AVAILABLE
  NOT_AVAILABLE
}

enum ManufacturingState {
  draft
  in_process
  finished
  affected
  cancel
}

enum PurchaseOrderState {
  draft
  purchase
  pending
  done
  cancel
}

model InvoicingPaymentTerm {
  id     String  @id @default(cuid())
  name   String  @unique
  amount Float   @default(1000)
  days   Int     @default(0)
  active Boolean @default(true)

  createUid String   @map("create_uid")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  PurchaseOrders PurchaseOrder[]

  @@map("invoicing_payment_term")
}

model InvoicingTax {
  id          String     @id @default(cuid())
  name        String     @unique
  description String
  amount      Float      @default(0.0)
  active      Boolean    @default(true)
  typeUse     TaxTypeUse @default(sale) @map("type_use")

  createUid  String            @map("create_uid")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  PTSale     ProductTemplate[] @relation("PTSaleTax")
  PTPurchase ProductTemplate[] @relation("PTPurchaseTax")

  @@map("invoicing_tax")
}

enum TaxTypeUse {
  sale
  purchase
}

model InvoicingCurrency {
  id          String  @id @default(cuid())
  name        String  @unique
  description String
  label       String
  symbol      String
  active      Boolean @default(true)

  @@map("invoicing_currency")
}

// INVOCES

model AccountInvoice {
  id             String   @id @default(cuid())
  name           String   @unique
  ref            String
  date           DateTime @db.Date //fecha de recepción
  invoiceDate    DateTime @map("invoice_date") @db.Date // fecha de proveedor
  invoiceDateDue DateTime @map("invoice_date_due") @db.Date // a partir de fecha proveedor

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("account_invoice")
}
