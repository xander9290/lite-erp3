generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Partner {
  id       String  @id @default(cuid())
  name     String
  email    String?
  imageUrl String?

  phone       String?
  mobile      String?
  street      String?
  houseNumber String? @map("house_number")
  streets     String?
  town        String?
  zip         Int?
  county      String?
  province    String?
  country     String?
  vat         String?

  displayType PartnerDisplayType @default(INTERNAL) @map("display_type")
  active      Boolean            @default(true)

  User User? @relation("PartnerUserRelated")

  Company Company? @relation("PartnerCompanyRel")

  userId      String? @map("user_id")
  UserManager User?   @relation("PartnerManagerRel", references: [id], fields: [userId], onDelete: Cascade)

  Products ProductTemplate[] @relation("ProductSupplierRel") //Proveedor en productos

  createdUid String   @map("created_uid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@map("partners")
}

enum PartnerDisplayType {
  INTERNAL
  CUSTOMER
  SUPPLIER
  CONTACT
  DELIVERY
}

model User {
  id        String    @id @default(cuid())
  name      String
  login     String    @unique
  password  String
  lastLogin DateTime? @map("last_login")
  active    Boolean   @default(true)

  partnerId String?  @unique @map("partner_id")
  Partner   Partner? @relation("PartnerUserRelated", fields: [partnerId], references: [id], onDelete: Cascade)

  Group   Group?  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId String? @map("group_id")

  ManagedCompanies Company[] @relation("UserManageCompanyRel")

  Companies Company[] @relation("UserCompanyRel")

  PartnerManager Partner[] @relation("PartnerManagerRel")

  Products ProductTemplate[] @relation("ProductUserRel") //Comprador designado en productos

  Auditlogs Auditlog[] @relation("UserAuditlogRel")

  createdUid String   @map("created_uid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Auditlog {
  id         String          @id @default(cuid())
  action     AuditlogActions
  entityType String          @map("entity_type")
  entityId   String          @map("entity_id")
  log        String

  userId String @map("user_id")
  User   User   @relation("UserAuditlogRel", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([entityType, entityId, createdAt])
  @@index([userId])
  @@map("auditlogs")
}

enum AuditlogActions {
  create
  update
  read
  delete
}

model Group {
  id     String  @id @default(cuid())
  name   String  @unique
  active Boolean @default(true)

  Users User[]

  GroupLines GroupLine[] @relation("GroupLineRel")

  createdUid String   @map("created_uid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("groups")
}

model GroupLine {
  id         String  @id @default(cuid())
  entityType String  @map("entity_type")
  fieldName  String  @map("field_name")
  invisible  Boolean @default(false)
  readonly   Boolean @default(false)
  required   Boolean @default(false)
  notCreate  Boolean @default(false) @map("not_create")
  notEdit    Boolean @default(false) @map("not_edit")

  modelId String @map("model_id")
  fieldId String @map("field_id")

  groupId String @map("group_id")
  Group   Group  @relation("GroupLineRel", fields: [groupId], references: [id], onDelete: Cascade)

  createdUid String   @map("created_uid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([entityType, fieldName])
}

model Model {
  id          String  @id @default(cuid())
  name        String  @unique // [label] description
  label       String  @unique
  description String
  active      Boolean @default(false)

  ModelFields ModelField[] @relation("ModelFieldRel")

  createdUid String   @map("created_uid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("models")
}

model ModelField {
  id          String    @id @default(cuid())
  name        String // [label] description
  label       String
  description String
  fieldType   FieldType @map("field_type")
  active      Boolean   @default(false)

  modelId String @map("model_id")
  Model   Model  @relation("ModelFieldRel", fields: [modelId], references: [id], onDelete: Cascade)

  createdUid String   @map("created_uid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@map("model_fields")
}

enum FieldType {
  string
  number
  relation
  action
  link
  boolean
  date
  datetime
}

model Tag {
  id   String @id @default(cuid())
  name String @unique

  ProductTemplate ProductTemplate[]

  @@map("tags")
}

model Company {
  id     String  @id @default(cuid())
  name   String  @unique
  code   String  @unique
  active Boolean @default(true)

  Users User[] @relation("UserCompanyRel")

  managerId String? @map("manager_id")
  Manager   User?   @relation("UserManageCompanyRel", fields: [managerId], references: [id], onDelete: Cascade)

  partnerId String  @unique @map("partner_id")
  Partner   Partner @relation("PartnerCompanyRel", fields: [partnerId], references: [id], onDelete: Cascade)

  //Es sucursal de o empresa Matriz   
  parentId String?   @map("parent_id")
  Company  Company?  @relation("ParentChildrenCompany", fields: [parentId], references: [id], onDelete: Cascade)
  Children Company[] @relation("ParentChildrenCompany")

  Warehouses Warehouse[] @relation("WarehouseCompanyRel")

  createdUid String   @map("created_uid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("companies")
}

model Warehouse {
  id          String        @id @default(cuid())
  name        String        @unique
  code        String        @unique
  description String        @unique
  type        WarehouseType @default(SALES)
  active      Boolean       @default(true)

  companyId String  @map("company_id")
  Company   Company @relation("WarehouseCompanyRel", fields: [companyId], references: [id], onDelete: Cascade)

  InternalsFrom Warehouse[] @relation("InternalsWarehouseRel")
  InternalsTo   Warehouse[] @relation("InternalsWarehouseRel")

  createdUid String   @map("created_uid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("warehouses")
}

enum WarehouseType {
  SALES
  SUPPLY
  PRODUCTION
  QUARANTINE
  ADJUSTMENT
  TRANSIT
}

model ProductTemplate {
  id                 String             @id @default(cuid())
  name               String             @unique
  description        String             @unique
  defaultCode        String             @unique @map("default_code")
  displayType        ProductDisplayType @default(PRODUCT) @map("display_type")
  state              ProductStateType   @default(AVAILABLE)
  active             Boolean            @default(true)
  sales              Boolean            @default(true)
  purchases          Boolean            @default(true)
  imageUrl           String?            @default("/image/avatar_default.svg") @map("image_url")
  price1             Float              @default(0.00) @map("price_1")
  price2             Float              @default(0.00) @map("price_2")
  price3             Float              @default(0.00) @map("price_3")
  price4             Float              @default(0.00) @map("price_4")
  price5             Float              @default(0.00) @map("price_5")
  lastCost           Float              @default(0.00) @map("last_cost")
  weight             Float              @default(0.00)
  volume             Float              @default(0.00)
  ancho              Float              @default(0.00)
  alto               Float              @default(0.00)
  largo              Float              @default(0.00)
  uomIncomingAllowed Float              @default(1.0) @map("uom_incoming_allowed")
  uomOutgoingAllowed Float              @default(1.0) @map("uom_outgoing_allowed")

  productCategoryId String?          @map("product_category_id")
  ProductCategory   ProductCategory? @relation(fields: [productCategoryId], references: [id])

  supplierId String?  @map("supplier_id")
  Supplier   Partner? @relation("ProductSupplierRel", fields: [supplierId], references: [id])

  userId String? @map("user_id")
  User   User?   @relation("ProductUserRel", fields: [userId], references: [id])

  Tags Tag[]

  createUid String   @map("create_uid")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("product_template")
}

model ProductCategory {
  id          String @id @default(cuid())
  name        String @unique
  description String @unique

  parentId String?           @map("parent_id")
  Parent   ProductCategory?  @relation("ParentProductCategoryRel", fields: [parentId], references: [id], onDelete: Cascade)
  Children ProductCategory[] @relation("ParentProductCategoryRel")

  Products ProductTemplate[]

  createUid String   @map("create_uid")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("product_category")
}

enum ProductDisplayType {
  CONSU
  SERVICE
  PRODUCT
}

enum ProductStateType {
  AVAILABLE
  NOT_AVAILABLE
}
