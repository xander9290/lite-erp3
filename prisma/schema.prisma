generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Partner {
  id       String  @id @default(cuid())
  name     String
  email    String?
  imageUrl String?

  displayType PartnerDisplayType @default(INTERNAL) @map("display_type")

  User User? @relation("PartnerUserRelated")

  createdUid String   @map("created_uid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@map("partners")
}

enum PartnerDisplayType {
  INTERNAL
  CUSTOMER
  SUPPLIER
  CONTACT
  DELIVERY
}

model User {
  id        String    @id @default(cuid())
  name      String
  login     String    @unique
  password  String
  lastLogin DateTime? @map("last_login")
  active    Boolean   @default(true)

  managerId   String? @map("manager_id")
  Manager     User?   @relation("ManagerRelation", fields: [managerId], references: [id], onDelete: Cascade)
  TeamMembers User[]  @relation("ManagerRelation")

  partnerId String?  @unique @map("partner_id")
  Partner   Partner? @relation("PartnerUserRelated", fields: [partnerId], references: [id], onDelete: Cascade)

  Group   Group?  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId String? @map("group_id")

  Auditlogs Auditlog[] @relation("UserAuditlogRel")

  createdUid String   @map("created_uid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Auditlog {
  id         String          @id @default(cuid())
  action     AuditlogActions
  entityType String          @map("entity_type")
  entityId   String          @map("entity_id")
  log        String

  userId String @map("user_id")
  User   User   @relation("UserAuditlogRel", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([entityType, entityId, createdAt])
  @@index([userId])
  @@map("auditlogs")
}

enum AuditlogActions {
  create
  update
  read
  delete
}

model Group {
  id     String  @id @default(cuid())
  name   String  @unique
  active Boolean @default(true)

  Users User[]

  GroupLines GroupLine[] @relation("GroupLineRel")

  createdUid String   @map("created_uid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("groups")
}

model GroupLine {
  id         String  @id @default(cuid())
  entityType String  @map("entity_type")
  fieldName  String  @map("field_name")
  invisible  Boolean @default(false)
  readonly   Boolean @default(false)
  required   Boolean @default(false)
  notCreate  Boolean @default(false) @map("not_create")
  notEdit    Boolean @default(false) @map("not_edit")

  modelId String @map("model_id")
  fieldId String @map("field_id")

  groupId String @map("group_id")
  Group   Group  @relation("GroupLineRel", fields: [groupId], references: [id], onDelete: Cascade)

  createdUid String   @map("created_uid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([entityType, fieldName])
}

model Model {
  id          String  @id @default(cuid())
  name        String  @unique // [label] description
  label       String  @unique
  description String
  active      Boolean @default(false)

  ModelFields ModelField[] @relation("ModelFieldRel")

  createdUid String   @map("created_uid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("models")
}

model ModelField {
  id          String    @id @default(cuid())
  name        String // [label] description
  label       String
  description String
  fieldType   FieldType @map("field_type")
  active      Boolean   @default(false)

  modelId String @map("model_id")
  Model   Model  @relation("ModelFieldRel", fields: [modelId], references: [id], onDelete: Cascade)

  createdUid String   @map("created_uid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@map("model_fields")
}

enum FieldType {
  string
  number
  relation
  action
  link
  boolean
  date
  datetime
}

model Tag {
  id   String @id @default(cuid())
  name String @unique

  @@map("tags")
}
